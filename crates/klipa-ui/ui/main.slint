// klipa — Slint UI markup.
// Ultra-light Liquid Glass surface: zero external assets, zero shaders,
// works identically on macOS / Windows / Linux.

import { LineEdit, ListView } from "std-widgets.slint";

struct HistoryRow {
    id: string,
    title: string,
    pin: string,
    shortcut-label: string,    // "⌘1", "⌘2", … "⌘9", or empty
    is-selected: bool,
}

struct FooterAction {
    label: string,
    shortcut-label: string,
    action-id: string,         // "clear" | "prefs" | "about" | "quit"
    is-selected: bool,
}

// Multi-layer Liquid Glass surface.
//
// Layer 1 (base): vertical dark gradient — gives depth.
// Layer 2 (highlight): faint white wash near the top — reads as a
//                      glass reflection on every OS without needing
//                      a real backdrop-blur shader.
// Layer 3 (border):  hairline at 10 % alpha — separates from desktop.
component GlassSurface inherits Rectangle {
    background: transparent;

    Rectangle {
        background: @linear-gradient(180deg,
            rgba(36, 36, 38, 0.82) 0%,
            rgba(22, 22, 24, 0.90) 100%);
        border-radius: 14px;
        border-width: 0.5px;
        border-color: rgba(255, 255, 255, 0.10);
    }
    Rectangle {
        y: 0;
        height: 64px;
        background: @linear-gradient(180deg,
            rgba(255, 255, 255, 0.085) 0%,
            rgba(255, 255, 255, 0.000) 100%);
        border-radius: 14px;
    }
}

// One row in the history list, also reused for footer items because
// the visual treatment is identical.
component MenuRow inherits Rectangle {
    in property <string> label;
    in property <string> shortcut-label;
    in property <bool> is-selected;
    callback clicked;
    callback double-clicked;

    height: 28px;
    border-radius: 8px;
    background: is-selected ? rgba(10, 132, 255, 0.85) : transparent;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        alignment: stretch;

        Text {
            text: root.label;
            font-size: 13px;
            font-weight: 300;
            color: is-selected ? white : rgba(255, 255, 255, 0.92);
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: root.shortcut-label;
            font-size: 11px;
            font-weight: 400;
            color: is-selected ? rgba(255, 255, 255, 0.85) : rgba(255, 255, 255, 0.40);
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
        double-clicked => { root.double-clicked(); }
    }
}

export component KlipaWindow inherits Window {
    // Data in.
    in property <[HistoryRow]> items;
    in property <[FooterAction]> footer-actions;
    in-out property <string> query;
    in property <int> selected-index;

    // Callbacks out.
    callback query-changed(string);
    callback row-clicked(int);
    callback row-activated(int);
    callback row-delete-requested(int);
    callback footer-clicked(string);
    callback key-pressed(KeyEvent);

    title: "klipa";
    width: 460px;
    height: 520px;
    background: transparent;
    no-frame: true;

    GlassSurface { width: 100%; height: 100%; }

    VerticalLayout {
        padding: 10px;
        spacing: 0px;

        // ── Header: app name + inline search ─────────────────────────
        HorizontalLayout {
            spacing: 10px;
            padding-left: 4px;
            padding-right: 4px;
            padding-bottom: 8px;

            Text {
                text: "klipa";
                font-size: 13px;
                font-weight: 200;
                color: rgba(255, 255, 255, 0.55);
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
                height: 28px;
                background: rgba(255, 255, 255, 0.06);
                border-radius: 8px;
                border-width: 0.5px;
                border-color: rgba(255, 255, 255, 0.08);

                HorizontalLayout {
                    padding-left: 9px;
                    padding-right: 9px;
                    spacing: 6px;
                    alignment: stretch;

                    Text {
                        text: "⌕";
                        font-size: 13px;
                        color: rgba(255, 255, 255, 0.45);
                        vertical-alignment: center;
                    }

                    LineEdit {
                        placeholder-text: "type to search…";
                        text <=> root.query;
                        font-size: 13px;
                        horizontal-stretch: 1;
                        edited(t) => { root.query-changed(t); }
                    }
                }
            }
        }

        // ── History list ─────────────────────────────────────────────
        ListView {
            vertical-stretch: 1;
            for row[i] in root.items: MenuRow {
                label: row.title;
                shortcut-label: row.shortcut-label;
                is-selected: row.is-selected;
                clicked => { root.row-clicked(i); }
                double-clicked => { root.row-activated(i); }
            }
        }

        // ── Hairline divider ─────────────────────────────────────────
        Rectangle {
            height: 0.5px;
            background: rgba(255, 255, 255, 0.10);
        }
        Rectangle { height: 4px; }

        // ── Footer (action items) ────────────────────────────────────
        for action[fi] in root.footer-actions: MenuRow {
            label: action.label;
            shortcut-label: action.shortcut-label;
            is-selected: action.is-selected;
            clicked => { root.footer-clicked(action.action-id); }
        }
    }

    // Single focus scope on top of everything so we get every keystroke.
    forward-focus: focus-scope;
    focus-scope := FocusScope {
        key-pressed(event) => {
            root.key-pressed(event);
            accept
        }
    }
}
